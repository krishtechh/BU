  road_pothole_filling
  road_resurfacing
  road_divider_repair
  road_footpath_repair
  road_speed_breaker
  water_pipe_leak
  water_supply_restoration
  water_valve_replacement
  water_meter_issues
  water_borewell
  drain_blockage
  drain_stormwater
  drain_manhole
  drain_sewage_overflow
  drain_pipe_repair
  san_public_toilet
  san_open_defecation
  san_sewage_treatment
  san_solid_waste
  san_street_sweeping
  san_dead_animal
  san_hospital_waste
  san_drain_cleaning
  san_graffiti
  san_toilet_block
  elec_power_outage
  elec_transformer
  elec_broken_wires
  elec_meter
  elec_illegal
  light_bulb_replacement
  light_wiring_fault
  light_pole_damage
  light_timer_fault
  light_solar
  garbage_household
  garbage_bulk
  garbage_construction
  garbage_hazardous
  garbage_green
  util_gas_pipeline
  util_broadband
