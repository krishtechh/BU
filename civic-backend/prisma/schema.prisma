generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(uuid())
  name                String
  email               String                @unique
  phone               String                @unique
  password            String
  role                Role                  @default(citizen)
  language            Language              @default(en)
  street              String?
  locality            String?
  city                String?
  state               String                @default("Jharkhand")
  pincode             String?
  latitude            Float?
  longitude           Float?
  profilePicture      String?
  isVerified          Boolean               @default(false)
  isActive            Boolean               @default(true)
  isDeleted           Boolean               @default(false)
  departmentName      String?
  assignedArea        String?
  verificationToken   String?
  resetPasswordToken  String?
  resetPasswordExpire DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  createdById         String?
  updatedById         String?
  chatParticipants    ChatParticipant[]
  comments            Comment[]
  headingDepartment   Department?           @relation("DeptHead")
  mediaUploaded       Media[]
  sentMessages        Message[]
  managedReports      Report[]              @relation("Assigner")
  assignedReports     Report[]              @relation("Assignee")
  createdReports      Report[]              @relation("Reporter")
  resolvedReports     Report[]              @relation("Resolver")
  statusChanges       ReportStatusHistory[]
  upvotes             Upvote[]
  createdBy           User?                 @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers        User[]                @relation("UserCreator")
  updatedBy           User?                 @relation("UserUpdater", fields: [updatedById], references: [id])
  updatedUsers        User[]                @relation("UserUpdater")
}

model Department {
  id                 String     @id @default(uuid())
  name               String     @unique
  code               String     @unique
  description        String?
  categories         Category[]
  headOfDepartmentId String?    @unique
  contactEmail       String?
  contactPhone       String?
  isActive           Boolean    @default(true)
  isDeleted          Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  headOfDepartment   User?      @relation("DeptHead", fields: [headOfDepartmentId], references: [id])
}

model Report {
  id                      String                @id @default(uuid())
  reporterId              String
  title                   String
  description             String
  category                Category
  priority                Priority              @default(medium)
  status                  Status                @default(submitted)
  address                 String
  locality                String?
  ward                    String?
  city                    String?
  pincode                 String?
  latitude                Float
  longitude               Float
  assignedToId            String?
  assignedById            String?
  assignedAt              DateTime?
  department              String?
  resolvedById            String?
  resolvedAt              DateTime?
  resolutionNotes         String?
  rating                  Int?
  feedbackComment         String?
  feedbackSubmittedAt     DateTime?
  estimatedResolutionTime DateTime?
  actualResolutionTime    Int?
  isAnonymous             Boolean               @default(false)
  viewCount               Int                   @default(0)
  isActive                Boolean               @default(true)
  isDeleted               Boolean               @default(false)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  comments                Comment[]
  media                   Media[]
  assignedBy              User?                 @relation("Assigner", fields: [assignedById], references: [id])
  assignedTo              User?                 @relation("Assignee", fields: [assignedToId], references: [id])
  reporter                User                  @relation("Reporter", fields: [reporterId], references: [id])
  resolvedBy              User?                 @relation("Resolver", fields: [resolvedById], references: [id])
  statusHistory           ReportStatusHistory[]
  upvotes                 Upvote[]
}

model Media {
  id            String    @id @default(uuid())
  reportId      String
  type          MediaType
  url           String
  cloudinaryId  String
  thumbnailUrl  String?
  fileName      String
  fileSize      Int
  mimeType      String
  duration      Float?
  width         Int?
  height        Int?
  caption       String?
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  uploadedById  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isBeforeMedia Boolean   @default(true)
  report        Report    @relation(fields: [reportId], references: [id])
  uploadedBy    User      @relation(fields: [uploadedById], references: [id])
}

model ReportStatusHistory {
  id          String   @id @default(uuid())
  reportId    String
  status      Status
  changedById String
  changedAt   DateTime @default(now())
  comment     String?
  changedBy   User     @relation(fields: [changedById], references: [id])
  report      Report   @relation(fields: [reportId], references: [id])
}

model Comment {
  id         String   @id @default(uuid())
  reportId   String
  userId     String
  text       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  report     Report   @relation(fields: [reportId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model Upvote {
  id       String @id @default(uuid())
  reportId String
  userId   String
  report   Report @relation(fields: [reportId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([reportId, userId])
}

model Chat {
  id              String            @id @default(uuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  participants    ChatParticipant[]
  messages        Message[]
}

model ChatParticipant {
  id     String @id @default(uuid())
  chatId String
  userId String
  chat   Chat   @relation(fields: [chatId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  content   String
  isSeen    Boolean  @default(false)
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])
}

enum Role {
  citizen
  staff
  supervisor
  admin
  demo
}

enum Language {
  en
  hi
  ho
  sa
  ku
  mu
}

